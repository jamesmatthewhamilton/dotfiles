#!/usr/bin/env bash
# --- Global Git Pre-Commit Hooks ---
for f in ~/.common/*.sh; do [ -f "$f" ] && . "$f"; done

name="$(git config user.name)"
email="$(git config user.email)"

if [ -z "$name" ] || [ -z "$email" ]; then
    printf "\n"
    printf "${WARNING}Git identity is not fully configured for this repo.\n"
    [ -z "$name" ]  && printf "  - user.name is not set\n"
    [ -z "$email" ] && printf "  - user.email is not set\n"
    printf "\n"
    printf "${HINT}\n"
    printf "git config --global user.name  \"Your Name\"\n"
    printf "git config --global user.email \"you@example.com\"\n"
    printf "\n"
    exit 1
fi
